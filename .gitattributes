# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text eol=lf

# PHP
*.php text eol=lf

# JavaScript / CSS / HTML
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf

# JSON data
*.json text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary output formats (AGENTS.md §Output artifact exclusion)
*.pdf binary
*.xlsx binary
*.zip binary
