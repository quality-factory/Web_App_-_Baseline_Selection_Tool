#!/bin/sh
# commit-msg hook: validate conventional commit format.
#
# Mirrors the CI check in .github/workflows/pr-title.yml.
# Valid format: type(scope): description
# Valid types: feat, fix, refactor, test, ci, docs, chore
#
# The first line of the commit message is checked. Merge commits
# and fixup/squash commits are allowed through without validation.
#
# Bypass in a legitimate emergency:
#   git commit --no-verify
#
# Install:
#   git config core.hooksPath hooks

MSG_FILE="$1"
FIRST_LINE=$(head -n 1 "$MSG_FILE")

# Allow merge commits (generated by git merge).
case "$FIRST_LINE" in
    Merge\ *) exit 0 ;;
    fixup!\ *|squash!\ *|amend!\ *) exit 0 ;;
esac

# Conventional commit regex -- matches pr-title.yml pattern exactly.
PATTERN='^(feat|fix|refactor|test|ci|docs|chore)(\(.+\))?: .+'

if ! echo "$FIRST_LINE" | grep -qE "$PATTERN"; then
    echo "REJECTED: commit message does not match conventional commit format." >&2
    echo "" >&2
    echo "  Expected: type(scope): description" >&2
    echo "  Valid types: feat, fix, refactor, test, ci, docs, chore" >&2
    echo "  Got: $FIRST_LINE" >&2
    echo "" >&2
    echo "  Bypass: git commit --no-verify" >&2
    exit 1
fi

exit 0
